<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h2>Products Admin page</h2>
    <a href="/products/add">Add products</a>
    <ol>

        <% Products.forEach(product=>{ %>
            <li>
                <%= product.name %>-<%= product.description%>-<% product.price %>-<%= products.imageUrl %>
            </li>



            <% })%>
    </ol>

</body>

</html>