<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
</head>

<body>
    <h1>Products Page</h1>
    <div class="row">
        <% products.forEach(product=> { %>
            <div class="box">
                <img src="<%= product.imageUrl %>" width="370px" alt="product image" />
                <h2>
                    PRODUCT: <%= product.name %>
                </h2>
                <p>
                    <b>DESCRIPTION:</b>
                    <%= product.description %>
                </p>

                <h4>
                    <b>PRICE:</b>
                    <%= product.price.toFixed(2) %> $/rs
                </h4>
            </div>
            <% }) %>
    </div>
</body>

</html>